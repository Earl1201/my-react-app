PORT=5000
NODE_ENV=production

# Railway MySQL — copy these from your Railway MySQL service Variables tab
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# JWT — use a long random string in production
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Your Vercel frontend URL (fill in after Vercel deployment)
CLIENT_URL=
